<script>
    function startScan() {
        const uploadUI = document.getElementById('upload-ui');
        const line = document.getElementById('line');
        const results = document.getElementById('results');
        const deals = document.getElementById('deals-section');
        const diagText = document.getElementById('diagnostic-text');

        uploadUI.classList.add('hidden');
        line.style.display = 'block';

        setTimeout(() => {
            line.style.display = 'none';
            results.classList.remove('hidden');
            deals.classList.remove('hidden');

            const issues = [
                "[CRITICAL] P0420: Catalyst System Efficiency Below Threshold",
                "[WARNING] Low Brake Fluid Pressure - Check Lines",
                "[INFO] Misfire Detected in Cylinder 2 - Check Spark Plugs",
                "[WARNING] Cooling System Fan Circuit Malfunction"
            ];
            
            diagText.innerText = issues[Math.floor(Math.random() * issues.length)];
        }, 3500); 
    }

    function filterParts() {
        let input = document.getElementById('partSearch').value.toLowerCase();
        let cards = document.getElementsByClassName('deal-card');
        
        for (let i = 0; i < cards.length; i++) {
            let name = cards[i].getAttribute('data-name');
            if (name) {
                if (name.includes(input)) {
                    cards[i].style.display = "";
                } else {
                    cards[i].style.display = "none";
                }
            }
        }
    }
</script>

